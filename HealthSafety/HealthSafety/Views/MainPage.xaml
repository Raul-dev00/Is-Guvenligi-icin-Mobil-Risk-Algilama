<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:HealthSafety.Converters" 
             x:Class="HealthSafety.Views.MainPage"
             Shell.NavBarIsVisible="False"
             Title="İş Güvenliği İzleme"
             BackgroundColor="#12161A">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *, Auto, Auto" Padding="20" RowSpacing="20">

        <Border Grid.Row="0"
                BackgroundColor="{Binding NetworkColor}" 
                StrokeThickness="0"
                Padding="12">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                <Label Text="📡" FontSize="16" VerticalOptions="Center" />
                <Label Text="{Binding NetworkStatusText}" 
                       TextColor="#FFFFFF" 
                       FontSize="14"
                       FontAttributes="Bold" 
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <Grid Grid.Row="1" VerticalOptions="Center" HorizontalOptions="Center">
            <Border WidthRequest="220" 
                    HeightRequest="220" 
                    BackgroundColor="Transparent"
                    Stroke="#1F252E"
                    StrokeThickness="8">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="110" />
                </Border.StrokeShape>
            </Border>

            <Border WidthRequest="180" 
                    HeightRequest="180" 
                    BackgroundColor="#1A2026"
                    Stroke="#00A8E8" StrokeThickness="2">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="90" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#00A8E8" Offset="0,0" Radius="20" Opacity="0.3" />
                </Border.Shadow>

                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="5">
                    <Label Text="🛡️" FontSize="35" HorizontalOptions="Center" />
                    <Label Text="DURUM" 
                           TextColor="#8A9CA8" 
                           FontSize="12" 
                           FontAttributes="Bold"
                           CharacterSpacing="2"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding StatusText}" 
                           TextColor="#FFFFFF" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center" 
                           Margin="10,0" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="15">
            <Button Grid.Column="0"
                    Text="▶ BAŞLAT" 
                    Command="{Binding StartCommand}"
                    IsEnabled="{Binding IsMonitoring, Converter={StaticResource InverseBoolConverter}}"
                    BackgroundColor="#00E676" TextColor="#0B1319"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="8"
                    HeightRequest="60" />

            <Button Grid.Column="1"
                    Text="⬛ DURDUR" 
                    Command="{Binding StopCommand}"
                    IsEnabled="{Binding IsMonitoring}"
                    BackgroundColor="#3F4D5A" TextColor="#FFFFFF"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="8"
                    HeightRequest="60" />
        </Grid>

        <Border Grid.Row="3" 
                Padding="5" 
                BackgroundColor="#2A1113" 
                Stroke="#FF3B30" 
                StrokeThickness="2" 
                Margin="0,10,0,10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>

            <Button Text="⚠️ ACİL DURUM (SOS)" 
                    Command="{Binding SosCommand}"
                    BackgroundColor="#FF3B30"
                    TextColor="#FFFFFF"
                    FontAttributes="Bold"
                    FontSize="22"
                    HeightRequest="90"
                    CornerRadius="8">
                <Button.Shadow>
                    <Shadow Brush="#FF3B30" Offset="0,0" Radius="25" Opacity="0.6" />
                </Button.Shadow>
            </Button>
        </Border>

    </Grid>
</ContentPage>