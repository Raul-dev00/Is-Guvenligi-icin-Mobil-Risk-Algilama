# PostgreSQL (Postgres.app örneği — kullanıcı adınızı güncelleyin)
DATABASE_URL="postgresql://aliyilmaz@localhost:5432/isg_risk_db?schema=public"

# Docker ile kullanıyorsanız:
# DATABASE_URL="postgresql://isg_user:isg_password@localhost:5432/isg_risk_db?schema=public"

# Backend
PORT=3000
NODE_ENV=development
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Telegram (kritik/yüksek alarmlar)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
